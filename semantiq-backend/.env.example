# SemantIQ Environment Variables
# Copy this file to .env and fill in your keys before running the server.

# SerpAPI key — get one free at https://serpapi.com (100 searches/month free tier)
SERPAPI_KEY=your_serpapi_key_here

# Optional: Google Knowledge Graph API key (for real KG entity lookups in step 3)
# Get one at https://console.cloud.google.com/apis/library/kgsearch.googleapis.com
GOOGLE_KG_KEY=your_google_kg_key_here
